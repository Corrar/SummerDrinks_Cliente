# Copie para .env e preencha. NUNCA commitar .env com valores reais.
NODE_ENV=development
PORT=3000

# PostgreSQL (Neon serverless compatível)
DATABASE_URL=postgres://usuario:senha@host/db?sslmode=require

# JWT — segredo forte, T_exp curto
JWT_SECRET=troque-por-um-segredo-forte-de-32+-bytes
JWT_EXP_SEGUNDOS=900

# CORS — allowlist separada por vírgula (painel + app do cliente). Sem '*' em produção.
CORS_ORIGINS=http://localhost:5173,https://painel.summerdrinks.app,https://app.summerdrinks.app

# Rate limit da borda pública
PUBLIC_RATE_MAX=5
PUBLIC_RATE_JANELA_MS=60000
